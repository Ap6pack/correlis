CORRELIS_HOST=0.0.0.0
CORRELIS_PORT=8080
CORRELIS_LOG_LEVEL=INFO
CORRELIS_SCENARIO_DIR=./scenarios
CORRELIS_ALEMBIC_CONFIG=./alembic.ini

CORRELIS_DATABASE_URL=postgresql+psycopg://correlis:correlis@localhost:5432/correlis

# Optional PostgreSQL integration-test database. This database is disposable: the
# test suite may migrate, truncate application tables, and downgrade it. Do not
# point this at the normal local development database.
CORRELIS_TEST_DATABASE_URL=postgresql+psycopg://correlis:correlis@localhost:5432/correlis_test

# Required for collector credential issuance and authentication.
# Generate a private value with at least 32 bytes of entropy:
# python -c 'import secrets; print(secrets.token_urlsafe(48))'
CORRELIS_CREDENTIAL_PEPPER=

# Ingestion request controls; body bytes are enforced independently of batch item count.
CORRELIS_INGEST_MAX_BODY_BYTES=2097152
CORRELIS_INGEST_MAX_BATCH_SIZE=100
CORRELIS_QUERY_DEFAULT_PAGE_SIZE=50
CORRELIS_QUERY_MAX_PAGE_SIZE=200
